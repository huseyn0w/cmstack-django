# Copy this file to .env and adjust values. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# Which settings module to load: config.settings.dev | config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# Secret key — generate a fresh one for any real deployment:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=dev-insecure-change-me

# Debug mode (dev only). Always False in production.
DJANGO_DEBUG=True

# Space- or comma-separated hosts.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database — DATABASE_URL takes precedence if set (e.g. postgres://user:pass@host:5432/name).
# These individual vars are what docker compose wires up by default.
POSTGRES_DB=cmstack_django
POSTGRES_USER=cmstack_django
POSTGRES_PASSWORD=cmstack_django
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Social login — Google (django-allauth). Leave blank to run without social login;
# the Sign in / Sign up pages still work with username/email + password.
# Create credentials at https://console.cloud.google.com/apis/credentials and set the
# authorized redirect URI to http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spam protection — reCAPTCHA v3 (django-recaptcha). Leave BOTH blank to run without
# a captcha: the comment form works exactly as before (graceful degradation). Set both
# to enable the invisible v3 captcha on the comment form. Create keys ("reCAPTCHA v3")
# at https://www.google.com/recaptcha/admin — the public/site key is rendered in HTML;
# the private/secret key is used server-side only and must never be committed.
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Recipient for public contact-form submissions. Leave blank to disable delivery
# (the form still works and thanks the visitor; nothing is emailed).
CONTACT_EMAIL=

# Frontend / Vite
# In dev with the Vite dev server running (npm run dev), set this True for HMR.
# When serving built assets (default docker compose up), keep it False.
DJANGO_VITE_DEV_MODE=False
DJANGO_VITE_DEV_SERVER_PORT=5173

# Media storage. By default uploads go to local disk (MEDIA_ROOT). To store them
# on an S3-compatible bucket (AWS S3, MinIO, Cloudflare R2), set USE_S3_MEDIA=1 and
# install requirements/prod.txt (pulls django-storages[s3]). Credentials are read
# from AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (standard boto3 env vars).
USE_S3_MEDIA=0
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_QUERYSTRING_AUTH=0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
